{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hangora.local/plugin-manifest.schema.json",
  "title": "Hangora Plugin Manifest",
  "description": "Describe any CLI tool to be wrapped by Hangora. v1 (W1)",
  "type": "object",
  "required": ["id", "displayName", "type"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,39}$",
      "description": "Unique id (used as adapterId in rooms). Lowercase, [a-z0-9_-], 1-40 chars."
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "UI label shown in member chips / plugin list."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$",
      "description": "Semver string. Optional but recommended."
    },
    "icon": {
      "type": "string",
      "maxLength": 8,
      "description": "Emoji / single icon char shown next to displayName."
    },
    "type": {
      "type": "string",
      "enum": ["spawn", "http"],
      "description": "spawn = local CLI subprocess; http = REST API. W1 ships spawn only."
    },

    "http": {
      "type": "object",
      "description": "http-only: REST API endpoint config. v0.54 W3-A.",
      "required": ["method", "url"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "url": {
          "type": "string",
          "minLength": 8,
          "maxLength": 2048,
          "description": "URL template, supports {param} substitution. Must be https:// or http://localhost."
        },
        "headers": {
          "type": "object",
          "maxProperties": 20,
          "description": "Static headers (templated). Keys must match ^[a-zA-Z0-9_-]+$."
        },
        "bodyTemplate": {
          "type": "string",
          "maxLength": 8192,
          "description": "POST/PUT/PATCH body template. JSON string with {param} placeholders. Empty = no body."
        },
        "replyJsonPath": {
          "type": "string",
          "maxLength": 200,
          "description": "jq-style path to extract reply text from JSON response. Empty = use raw text."
        },
        "tokensJsonPath": {
          "type": "string",
          "maxLength": 200,
          "description": "jq-style path to extract tokens count from JSON response (optional)."
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 600000,
          "default": 30000
        }
      }
    },

    "bin": {
      "type": "object",
      "description": "spawn-only: how to locate the executable.",
      "required": ["cmd"],
      "additionalProperties": false,
      "properties": {
        "cmd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Binary name or absolute path. Resolved via `which` at startup unless absolute."
        },
        "check": {
          "type": "string",
          "maxLength": 200,
          "description": "Optional `which X` style probe used to decide if plugin is registrable."
        },
        "fallback": {
          "type": "string",
          "maxLength": 400,
          "description": "Optional fallback absolute path (e.g. ~/.npm-global/bin/X) if `which` misses."
        },
        "env": {
          "type": "string",
          "maxLength": 80,
          "description": "Optional env var name overriding cmd (e.g. CLAUDE_BIN)."
        }
      }
    },

    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["stdin", "argv", "file"],
          "default": "stdin",
          "description": "How the prompt is delivered to the CLI."
        },
        "encoding": {
          "type": "string",
          "enum": ["utf-8", "utf-16", "ascii"],
          "default": "utf-8"
        },
        "filePathArg": {
          "type": "string",
          "description": "When mode=file: arg placeholder to substitute with temp file path (e.g. '-f' or '@'). Required if mode=file."
        }
      }
    },

    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["stream", "file"],
          "default": "stream",
          "description": "stream = collect stdout; file = read result file path"
        },
        "parser": {
          "type": "string",
          "enum": ["raw", "jsonl", "openai-stream", "claude-stream"],
          "default": "raw",
          "description": "How to extract reply text from output. W1 ships raw + jsonl."
        },
        "filePathArg": {
          "type": "string",
          "description": "When mode=file: arg the CLI uses to specify output path (e.g. '-o')."
        },
        "tokensRegex": {
          "type": "string",
          "maxLength": 200,
          "description": "Optional regex with 1 capture group to extract token count from stdout."
        },
        "replyJsonPath": {
          "type": "string",
          "maxLength": 200,
          "description": "Optional jq-style path (e.g. '.choices[0].message.content') for json/jsonl output."
        }
      }
    },

    "commands": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "name", "args"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.-]{0,60}$",
            "description": "Command id, dotted ok (e.g. 'agents.run')."
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 80 },
          "description": { "type": "string", "maxLength": 400 },
          "args": {
            "type": "array",
            "items": { "type": "string", "maxLength": 200 },
            "maxItems": 30,
            "description": "Argv template. Use {paramName} placeholders substituted from params."
          },
          "params": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,29}$" },
                "type": { "type": "string", "enum": ["string", "number", "boolean", "enum"] },
                "required": { "type": "boolean", "default": false },
                "default": {},
                "maxLen": { "type": "integer", "minimum": 1, "maximum": 1000000 },
                "min": { "type": "number" },
                "max": { "type": "number" },
                "enumValues": { "type": "array", "items": { "type": "string" }, "maxItems": 50 }
              }
            }
          }
        }
      }
    },

    "events": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^(stdout|stdout-jsonl|stderr|log-tail|sse:.+|ws:.+)$",
          "description": "Where events come from. W1: stdout / stdout-jsonl. W2: log-tail/sse/ws."
        },
        "path": {
          "type": "string",
          "maxLength": 500,
          "description": "For log-tail: absolute log file path (or ~/ shorthand)."
        },
        "schema": {
          "type": "string",
          "enum": ["raw", "openai", "claude-stream", "custom"],
          "default": "raw"
        }
      }
    },

    "dashboard": {
      "type": "array",
      "maxItems": 12,
      "description": "Cards rendered in the plugin tab. W1 spec only (renderer comes in W2 T7).",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["status-bar", "list", "log", "metric"] },
          "title": { "type": "string", "maxLength": 80 },
          "fields": { "type": "array", "items": { "type": "string", "maxLength": 80 }, "maxItems": 20 },
          "source": { "type": "string", "maxLength": 200 },
          "until": { "type": "string", "maxLength": 200 },
          "maxLines": { "type": "integer", "minimum": 1, "maximum": 5000 }
        }
      }
    },

    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cwdScope": {
          "type": "string",
          "enum": ["home-tree", "tmp-only", "explicit-list"],
          "default": "home-tree",
          "description": "Reuses panel's safeResolveFsPath sandbox. home-tree = ~/* + /tmp."
        },
        "explicitCwdList": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 },
          "maxItems": 20
        },
        "envWhitelist": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]{0,49}$" },
          "maxItems": 40,
          "default": ["LANG", "LC_ALL", "PATH"]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 7200000,
          "default": 1800000
        }
      }
    },

    "extra": {
      "type": "object",
      "description": "Adapter-specific knobs that don't fit elsewhere (e.g. claude --dangerously-skip-permissions). Free-form but bounded.",
      "maxProperties": 30
    }
  },

  "allOf": [
    {
      "if": { "properties": { "type": { "const": "spawn" } } },
      "then": { "required": ["bin"] }
    },
    {
      "if": { "properties": { "type": { "const": "http" } } },
      "then": { "required": ["http"] }
    },
    {
      "if": {
        "properties": { "input": { "properties": { "mode": { "const": "file" } } } },
        "required": ["input"]
      },
      "then": {
        "properties": { "input": { "required": ["filePathArg"] } }
      }
    }
  ]
}
