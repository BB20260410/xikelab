{
  "name": "roundtable",
  "version": "2.0.0",
  "productName": "Roundtable",
  "description": "Roundtable — Local-first multi-AI workbench. Supports Claude, GPT, Gemini, MiniMax, Ollama and 8+ providers. 4 collaboration modes (chat/debate/squad/arena), MCP one-stop, all data local 0o600.",
  "author": "hxx",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron electron-main.js",
    "start:electron": "electron electron-main.js",
    "package": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "dist:all": "electron-builder --mac --win --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf-check": "node scripts/perf-check.mjs",
    "test:e2e": "node tests/e2e/panel-ui-walkthrough.mjs",
    "dist:publish": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "node-pty": "^1.0.0",
    "pino": "^10.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.hxx.claude-panel",
    "productName": "Roundtable",
    "asar": true,
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**"
    ],
    "directories": {
      "output": "out"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BB20260410",
        "repo": "roundtable",
        "releaseType": "release"
      }
    ],
    "files": [
      "server.js",
      "electron-main.js",
      "public/**",
      "src/**",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Roundtable v${version}",
      "writeUpdateInfo": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": "nsis"
    }
  }
}
